{
  "name": "sheetwatch-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "dev:api": "ts-node-dev --respawn --transpile-only src/api/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/index.ts",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "bullmq": "^5.12.0",
    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^173.0.0",
    "ioredis": "^5.4.1",
    "resend": "^3.4.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/web-push": "^3.6.3",
    "prisma": "^5.15.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "overrides": {
    "google-auth-library": "10.7.0"
  }
}
